
# Token Expiry Notifications
# Webhook URL to receive expiry notifications (e.g., Slack, Discord, ntfy.sh)
# NOTIFICATION_WEBHOOK_URL=https://ntfy.sh/your-topic

# Hours before expiry to trigger warning (default: 24)
# AUTH_EXPIRY_WARNING_HOURS=24

# Interval in seconds between expiry checks (default: 3600 = 1 hour)
# AUTH_EXPIRY_CHECK_INTERVAL=3600

# Tomorrow.io API key for the live weather-radar overlay on the
# weather tile. Free tier (25 req/h, 500 req/day) is sufficient — the
# radar capture runs at 1 fetch every ~3 min, from 15 min before each
# session until 5 min after. Get a key at:
#   https://app.tomorrow.io/development/keys
# TOMORROW_API_KEY=your-tomorrow-io-key
