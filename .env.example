
# To keep the ephemeral data generated during processing and analysis uncomment the following line
# REPLAY_DEBUG=1

# Base directory for app data (livetiming cache, analysis, transient DBs,
# weather-radar tiles). Defaults to an OS-appropriate location:
#   Windows: %LOCALAPPDATA%\F1Unleashed
#   macOS:   ~/Library/Application Support/F1Unleashed
#   Linux:   $XDG_DATA_HOME/f1unleashed  (or ~/.local/share/f1unleashed)
# Set this to override — e.g. to keep using an existing in-repo cache without
# moving files (existing data is NOT migrated automatically).
# F1U_DATA_DIR=/path/to/f1unleashed-data

# Token Expiry Notifications
# Webhook URL to receive notifications (e.g., Slack, Discord, ntfy.sh)
# NOTIFICATION_WEBHOOK_URL=https://ntfy.sh/your-topic

# Hours before token expiration to trigger warning (default: 24)
# AUTH_EXPIRY_WARNING_HOURS=24

# Interval in seconds between token expiration checks (default: 3600 = 1 hour)
# AUTH_EXPIRY_CHECK_INTERVAL=3600

# Rainbow.ai subscription key for the live weather-radar overlay on the
# weather tile. Free tier (30,000 calls/month, no hourly cap) is plenty.
# The radar capture builds one 2x2 zoom-12 composite every 10 min (= 5 calls:
# 1 snapshot + 4 tiles), from 15 min before each session until 5 min after.
# Get a key at:
#   https://developer.rainbow.ai/
# RAINBOW_AI_API_KEY=your-rainbow-ai-key
