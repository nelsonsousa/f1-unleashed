# Local per-checkout instance overrides. Copy to `instance.env` (gitignored) to
# run this checkout as a SECOND server alongside another (e.g. the ../live copy)
# without clashing on the port or sharing the data folder.
#
# Defaults (shown below) = the current single-instance values, so an absent or
# empty instance.env changes nothing. A real environment variable of the same
# name always wins over this file.

# Port the server binds. Default 1950.
PORT=1950

# Data home: settings.json, the livetiming cache, tmp DBs, analysis, weather
# cache and telemetry ALL live under here. Empty = OS default
# (macOS: ~/Library/Application Support/F1Unleashed).
# Point this at an ISOLATED directory to run beside another instance without
# sharing or clobbering its data.
F1_DATA_HOME=
